##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh does
#       not seem to be POSIX compliant, but you have some other shells available,
#       try using them to run this script.
#
#   (2) The slightest modification of this script may cause it to fail, so PLEASE
#       CAREFULLY edit only if you understand what you are doing.
#
#   (3) This script is generated from the corresponding *.gradle template and
#       should not be manually edited.
#
##############################################################################

# Attempt to set APP_HOME
# Resolve links: $0 may be a link
app_path=$0

# Need this for daisy-chained symlinks.
while
    APP_HOME=${app_path%"${app_path##*/}"}    # leaves a trailing /; empty if no leading path
    [ -h "$app_path" ]
do
    ls=$( ls -ld "$app_path" )
    link=${ls#*' -> '}
    case $link in             #(
      /*)   app_path=$link ;; #(
      *)    app_path=$APP_HOME$link ;;
    esac
done

# This is normally unused
APP_HOME=$( cd "${APP_HOME:-./}" && pwd -P ) || exit

APP_NAME="Gradle"
APP_BASE_NAME=${0##*/}
APP_HOME_RELATIVE=$( cd "$APP_HOME" > /dev/null && pwd -P && cd "$OLDPWD" >/dev/null && pwd -P | sed 's|[^/]*|..|g' | sed 's|/$||' )
CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

exec java \
  -Dorg.gradle.appname="$APP_BASE_NAME" \
  -classpath "$CLASSPATH" \
  org.gradle.wrapper.GradleWrapperMain \
  "$@"
