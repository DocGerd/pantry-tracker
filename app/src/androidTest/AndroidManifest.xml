<?xml version="1.0" encoding="utf-8"?>
<!--
  androidTest manifest.

  The test Application class (TestPantryTrackerApp) is NOT swapped here. The
  reliable on-device mechanism is the custom instrumentation runner
  (PantryTestRunner, set as testInstrumentationRunner in build.gradle.kts),
  which overrides newApplication() to force TestPantryTrackerApp. A manifest
  `android:name` override is unreliable: at runtime the Application is created
  from the *target* (app) manifest, which still names PantryTrackerApp, so the
  hard cast in ConfigChangeRotationTest would fail with a ClassCastException
  (this is the SR-78 on-device failure being fixed here).

  This manifest is intentionally minimal — no <application> override.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android" />
