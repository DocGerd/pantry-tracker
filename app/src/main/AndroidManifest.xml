<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- ACCESS_NETWORK_STATE is library-injected by Ktor's OkHttp engine + Coil
         (both use ConnectivityManager). Normal-protection, no PII. Documented
         in CHANGELOG under Privacy. -->
    <uses-feature
        android:name="android.hardware.camera.any"
        android:required="false" />

    <application
        android:name=".PantryTrackerApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.PantryTracker"
        tools:targetApi="36">
        <!-- Sever ML Kit's google-datatransport telemetry pipeline. The
             standard `firebase_data_collection_default_enabled=false` flag
             does NOT work in standalone (no-Firebase-project) ML Kit usage —
             it is only read by FirebaseInitProvider, which ML Kit does not
             register. Removing the backend + scheduler components is the
             working opt-out; the barcode detector does not depend on them.
             See CHANGELOG Privacy for full rationale. -->
        <service
            android:name="com.google.android.datatransport.runtime.backends.TransportBackendDiscovery"
            tools:node="remove" />
        <service
            android:name="com.google.android.datatransport.runtime.scheduling.jobscheduling.JobInfoSchedulerService"
            tools:node="remove" />
        <receiver
            android:name="com.google.android.datatransport.runtime.scheduling.jobscheduling.AlarmManagerSchedulerBroadcastReceiver"
            tools:node="remove" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:taskAffinity="">
            <!-- SR-1: empty taskAffinity prevents a hostile app from launching
                 MainActivity into its own task. The package-name default
                 leaves us open to a hostile app that explicitly sets
                 taskAffinity="de.docgerdsoft.pantrytracker" + uses
                 FLAG_ACTIVITY_NEW_TASK to inject itself into our task stack.
                 The blank string opts out of affinity grouping entirely. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
