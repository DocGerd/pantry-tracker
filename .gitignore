# Brainstorm / Claude scratch
.superpowers/

# Claude Code project-scoped automation IS committed (hooks, settings.json,
# skills/, agents/) so every contributor gets the same guardrails by default
# — see docs/superpowers/specs/2026-05-17-claude-automation-toolkit-design.md.
# Only the personal per-session prefs file is gitignored.
.claude/settings.local.json

# Android / Gradle build outputs
*.iml
.gradle/
.idea/
build/
local.properties
captures/
.externalNativeBuild/
.cxx/

# Gradle lockfile is regenerated each Security CI run from the current resolved
# graph — don't commit a developer-local snapshot or scans will report drift
# nobody can explain. Removing this entry + committing the lockfile is a valid
# alternative if reproducible builds become more important than always-current
# scan results.
gradle.lockfile

# Kotlin / IntelliJ
out/

